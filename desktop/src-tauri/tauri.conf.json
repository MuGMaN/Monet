{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Monet",
  "version": "1.0.20",
  "identifier": "com.monet.usage-monitor",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Monet",
        "width": 360,
        "height": 480,
        "resizable": false,
        "decorations": false,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "monet.desktop"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUyMDgwMkNGQzFGRDc3OTAKUldTUWQvM0J6d0lJNGxIdkN5dFJUbjdlajFTb0t0dmdPSUk2bU91bnVoT2krdXU0VjRTbXdQd3UK",
      "endpoints": [
        "https://gitlab.ericandjoe.work/eric/Monet/-/releases/permalink/latest/downloads/latest.json"
      ]
    }
  }
}
